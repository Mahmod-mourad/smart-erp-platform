{
  "info": {
    "name": "NexaFlow API",
    "description": "Sprint 1 auth + tenant + invitations. Login/Register auto-store {{accessToken}} and {{refreshToken}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5283/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', r.accessToken);",
                  "pm.collectionVariables.set('refreshToken', r.refreshToken);",
                  "pm.test('201/200', () => pm.expect(pm.response.code).to.be.oneOf([200,201]));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register-company", "host": ["{{baseUrl}}"], "path": ["auth", "register-company"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Acme Corp\",\n  \"adminFirstName\": \"Ada\",\n  \"adminLastName\": \"Lovelace\",\n  \"adminEmail\": \"admin@acme.com\",\n  \"password\": \"Sup3rSecret!\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', r.accessToken);",
                  "pm.collectionVariables.set('refreshToken', r.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@acme.com\",\n  \"password\": \"Sup3rSecret!\"\n}" }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Accept Invite",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/accept-invite", "host": ["{{baseUrl}}"], "path": ["auth", "accept-invite"] },
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"PASTE_INVITE_TOKEN\",\n  \"firstName\": \"Grace\",\n  \"lastName\": \"Hopper\",\n  \"password\": \"Sup3rSecret!\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Tenants",
      "item": [
        {
          "name": "Get Current Tenant",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/tenants/current", "host": ["{{baseUrl}}"], "path": ["tenants", "current"] }
          }
        }
      ]
    },
    {
      "name": "Invitations",
      "item": [
        {
          "name": "Invite Member",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/invitations", "host": ["{{baseUrl}}"], "path": ["invitations"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"teammate@acme.com\",\n  \"roleName\": \"Employee\"\n}" }
          }
        },
        {
          "name": "List Pending Invitations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/invitations", "host": ["{{baseUrl}}"], "path": ["invitations"] }
          }
        },
        {
          "name": "Revoke Invitation",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/invitations/:id", "host": ["{{baseUrl}}"], "path": ["invitations", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:5283/health", "host": ["http://localhost:5283"], "path": ["health"] }
      }
    }
  ]
}
